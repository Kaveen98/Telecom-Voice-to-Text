# OS/editor junk
.DS_Store
Thumbs.db

# Python caches
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# Local env/secrets
.env
.env.*
!.env.example
.dashboard_secret

# Logs
logs/**
!logs/
!logs/.gitkeep
*.log

# Runtime transcript/output folders
transcriptions/**
!transcriptions/
!transcriptions/**/
!transcriptions/**/.gitkeep
outputs/**
output/**

# Generated transcript and metadata artifacts
*_transcript.txt
*_metadata.json
*transcript*.json
batch_input_*.jsonl

# Input audio recordings and processing folders
input_audio/**
!input_audio/
!input_audio/.gitkeep
!input_audio/**/
!input_audio/**/.gitkeep
*.mp3
*.wav
*.m4a
*.ogg
*.flac
*.aac
*.opus

# Credentials and private key material
credentials/**
!credentials/
!credentials/.gitkeep
google-credentials.json
*credential*.json
*credentials*.json
*service-account*.json
*service_account*.json
*.pem
*.key

# Archives that may contain credentials, audio, or transcripts
*.zip
*.rar

# Local databases and dumps
calls.db
*.db
*.db-*
*.sqlite
*.sqlite3
*.dump
*.backup

# Local backups and experiments
_cleanup_backup/
experiments/

# Archive placeholders for inactive docs
!docs/
!docs/archive/
!docs/archive/batch/
!docs/archive/linux/
!docs/archive/**/.gitkeep
