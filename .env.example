# Telecom Voice-to-Text local configuration template.
# Copy this file to .env and edit local values. Never commit .env,
# credential JSON files, private keys, transcripts, logs, or real audio.

# Gemini / Vertex AI realtime transcription
GOOGLE_APPLICATION_CREDENTIALS=credentials/google-credentials.json
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
STT_GEMINI_LOCATION=us-central1

# MySQL is optional metadata/index storage.
# TXT transcript files and JSON metadata files are the primary output.
# If MySQL is unavailable, TXT/JSON saving should still work.
DB_ENABLED=true
DB_BACKEND=mysql
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=telecom_voice_to_text
MYSQL_USER=telecom_app
MYSQL_PASSWORD=change_this_password
MYSQL_CONNECT_TIMEOUT=10

# Optional daily estimated API cost safety guardrail.
# Protects against unexpected daily Gemini/Vertex API spending.
# Dashboard cost remains estimated API usage cost; exact invoices may differ.
# If DB is unavailable and policy is block, new paid requests are deferred.
DAILY_COST_LIMIT_ENABLED=false
DAILY_COST_LIMIT_LKR=1000
DAILY_COST_WARNING_PERCENT=80
COST_LIMIT_PREFLIGHT_ENABLED=true
COST_LIMIT_DB_FAILURE_POLICY=block

# Windows realtime folder workflow
INPUT_INCOMING_DIR=input_audio/incoming
INPUT_PROCESSING_DIR=input_audio/processing
INPUT_COMPLETED_DIR=input_audio/completed
INPUT_FAILED_DIR=input_audio/failed
INPUT_DEFERRED_DIR=input_audio/deferred
TRANSCRIPTIONS_DIR=transcriptions
LOG_DIR=logs

# App-local time and transcript folder naming
APP_TIMEZONE=Asia/Colombo
TRANSCRIPT_DATE_FORMAT=%Y.%m.%d
