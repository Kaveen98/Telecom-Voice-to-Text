# Google Cloud / Vertex AI
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Optional for local development with a JSON key.
# Leave unset when using Application Default Credentials or an attached VM
# service account. Set only when using a local JSON key file.
# GOOGLE_APPLICATION_CREDENTIALS=credentials/google-credentials.json

# Transcription runtime
STT_MODEL_NAME=gemini-2.5-flash
STT_LKR_RATE=316.0

# Audio preprocessing defaults match the current production behavior.
STT_STRIP_SILENCE=true
STT_SILENCE_START_THRESHOLD_DB=-40
STT_SILENCE_STOP_THRESHOLD_DB=-40
STT_SILENCE_START_DURATION=0.3
STT_SILENCE_STOP_DURATION=0.5
STT_PREPROCESS_PROFILE=ffmpeg_silenceremove_v1

# Local defaults are repo-relative when these are unset.
# Linux service example:
# STT_DATA_DIR=/var/lib/slt-transcription
# STT_INPUT_DIR=/var/lib/slt-transcription/input_audio
# STT_OUTPUT_DIR=/var/lib/slt-transcription/output
# STT_DB_PATH=/var/lib/slt-transcription/calls.db
# STT_LOG_DIR=/var/log/slt-transcription
# STT_LOG_FILE=/var/log/slt-transcription/watcher.log

# Dashboard
STT_DASHBOARD_HOST=0.0.0.0
STT_DASHBOARD_PORT=5050
STT_ENABLE_RESET=false

# Backward compatibility: STT_GEMINI_LOCATION is still accepted, but new
# deployments should use GOOGLE_CLOUD_LOCATION.
